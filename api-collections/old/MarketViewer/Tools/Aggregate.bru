meta {
  name: Aggregate
  type: http
  seq: 1
}

get {
  url: {{marketViewer_url}}/api/tools/aggregate?ticker=SPY&timespan=hour
  body: none
  auth: none
}

params:query {
  ticker: SPY
  timespan: hour
}

headers {
  Accept: */*
  Authorization: Bearer {{jwt}}
}

body:form-urlencoded {
  Ticker: AES
  Multiplier: 1
  Timespan: hour
  From: 2024-09-27
  To: 2024-11-28
  _study: macd:12,26,9,EMA
  ~_study: vwap
  ~_study: ema:9
  ~_study: ema:21
  ~_study: ema:200
}
