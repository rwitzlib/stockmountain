meta {
  name: Start app
  type: http
  seq: 1
}

post {
  url: {{managementUrl}}/api/deploy/start
  body: json
  auth: bearer
}

auth:bearer {
  token: {{deployToken}}
}

body:json {
  {
    "Environment": "dev",
    "Repository": "stockmountain-app",
    "File": "deploy.docker-compose.yml",
    "Image": "100008144700.dkr.ecr.us-east-2.amazonaws.com/lad-dev-stockmountain-app:master",
    "Actor": "local"
  }
}
