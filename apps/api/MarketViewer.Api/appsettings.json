{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient.IMassiveClient.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.IMassiveClient.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.OtlpTraceExporter.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.OtlpTraceExporter.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.OtlpLogExporter.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.OtlpLogExporter.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.OtlpMetricExporter.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.OtlpMetricExporter.LogicalHandler": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss.fff",
        "UseUtcTimestamp": true,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "AllowedHosts": "*"
}