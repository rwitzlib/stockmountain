{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.Default.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.Default.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.authentication.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.authentication.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.trader.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.trader.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.marketviewer.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.marketviewer.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.IMassiveClient.LogicalHandler": "Warning",
      "System.Net.Http.HttpClient.IMassiveClient.ClientHandler": "Warning"
    }
  },
  "Urls": {
    "MarketViewer": "https://api.stockmountain.io"
  },
  "StrategyConfig": {
    "PublicIndexName": "PublicIndex",
    "UserIndexName": "UserIndex",
    "StrategyHashIndexName": "StrategyHashIndex"
  },
  "TradeConfig": {
    "UserIndexName": "UserIndex",
    "StrategyIndexName": "StrategyIndex"
  },
  "UserConfig": {
    "PublicIndexName": "PublicIndex"
  },
  "SqsConsumerConfig": {
    "MaxNumberOfMessages": 10,
    "WaitTimeSeconds": 20,
    "VisibilityTimeoutSeconds": 60
  },
  "ScanResultsConfig": {
    "_comment": "TableName supplied via ScanResultsConfig__TableName env var"
  },
  "ExecutionDedupConfig": {
    "TtlDays": 7
  },
  "MetaConfig": {
    "_comment": "TableName supplied via MetaConfig__TableName env var"
  }
}
