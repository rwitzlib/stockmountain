{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient.IPolygonClient.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.IPolygonClient.LogicalHandler": "Warning"
    },
    "Console": {
      "FormatterOptions": {
        "IncludeScopes": true
      }
    }
  },
  "AllowedHosts": "*",
  "BacktestConfig": {
    "TableName": "lad-dev-marketviewer-backtest-store",
    "RequestDetailsIndexName": "RequestDetailsIndex",
    "UserIndexName": "UserIndex",
    "LambdaName": "lad-dev-backtest-worker",
    "S3BucketName": "lad-dev-marketviewer"
  },
  "UserConfig": {
    "TableName": "lad-dev-marketviewer-user-store",
    "PublicIndexName": "PublicIndex"
  }
}
